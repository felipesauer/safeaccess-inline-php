{
    "name": "safeaccess/inline",
    "version": "0.1.3",
    "description": "Safe nested data access with dot notation for PHP.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "safeaccess",
        "dot-notation",
        "nested-data",
        "data-access",
        "array-access",
        "object-access",
        "null-safe"
    ],
    "homepage": "https://github.com/felipesauer/safeaccess-inline",
    "authors": [
        {
            "name": "Felipe Sauer",
            "email": "felipesauer11@hotmail.com",
            "homepage": "https://github.com/felipesauer"
        }
    ],
    "support": {
        "issues": "https://github.com/felipesauer/safeaccess-inline/issues",
        "source": "https://github.com/felipesauer/safeaccess-inline/tree/main/packages/php"
    },
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "ext-simplexml": "*",
        "ext-libxml": "*"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "infection/infection": "^0.32.6"
    },
    "suggest": {
        "ext-yaml": "For improved YAML parsing performance (optional - a built-in minimal parser is used by default)"
    },
    "autoload": {
        "psr-4": {
            "SafeAccess\\Inline\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SafeAccess\\Inline\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest --bail --profile --coverage --strict-coverage --min=100",
        "test:coverage": "php -d pcov.enabled=1 vendor/bin/pest --bail --profile --coverage --strict-coverage --min=100",
        "test:mutation": "bash scripts/mutation.sh",
        "test:parity": "vendor/bin/pest tests/Unit/ParityTest.php",
        "analyse": "phpstan analyse",
        "format": "php-cs-fixer fix"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/felipesauer"
        }
    ],
    "minimum-stability": "alpha",
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "infection/extension-installer": true
        }
    }
}
